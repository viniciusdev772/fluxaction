# Flux Action - Environment Configuration
# ⚠️ IMPORTANTE: Não comite este arquivo! Ele já está no .gitignore

# ============================================
# REQUIRED CONFIGURATION
# ============================================

# Chave de criptografia de 32 bytes (64 caracteres hex)
# IMPORTANTE: Use uma chave única e segura para cada ambiente.
# Para gerar uma chave aleatória, execute:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BACKEND_ENCRYPTION_KEY=REPLACE_WITH_YOUR_GENERATED_KEY

# ============================================
# SERVER CONFIGURATION
# ============================================

# Porta interna do backend
PORT=4000

# Ambiente de execução (development, production)
NODE_ENV=production

# ============================================
# SECURITY CONFIGURATION
# ============================================

# CORS - Origens permitidas (separadas por vírgula)
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:5173

# Rate Limiting - Requisições permitidas por IP por janela de 15 minutos
RATE_LIMIT_GENERAL=100
RATE_LIMIT_CONFIG=10

# CSRF Protection - Ativado por padrão (true/false)
CSRF_PROTECTION=true

# Sync Interval - Intervalo de sincronização em minutos
SYNC_INTERVAL_MINUTES=5

# Request Timeout - Timeout para requisições ao n8n em milissegundos
REQUEST_TIMEOUT_MS=30000

# Max Search Length - Tamanho máximo do termo de busca
MAX_SEARCH_LENGTH=200

# ============================================
# LOGGING CONFIGURATION
# ============================================

# Log Level (debug, info, warn, error)
LOG_LEVEL=info

# Log File Path (opcional, apenas para produção)
# Se definido, logs serão escritos neste arquivo
# LOG_FILE_PATH=/app/logs/fluxaction.log

# ============================================
# DATABASE CONFIGURATION
# ============================================

# Caminho para o banco de dados SQLite (opcional)
# Padrão: /app/data/fluxaction.sqlite
# CONFIG_DB_PATH=/app/data/fluxaction.sqlite

# Caminho para o banco de dados de workflows (opcional)
# Padrão: /app/data/workflows.sqlite
# WORKFLOW_DB_PATH=/app/data/workflows.sqlite

# ============================================
# PRODUCTION NOTES
# ============================================

# Para produção com HTTPS:
# 1. Descomente o bloco HTTPS em proxy/nginx.conf
# 2. Configure certificados SSL em proxy/ssl/
# 3. Atualize ALLOWED_ORIGINS para seu domínio HTTPS
# 4. Gere uma nova BACKEND_ENCRYPTION_KEY
# 5. Configure LOG_FILE_PATH para persistência de logs
# 6. Considere usar um serviço de logs externo (ELK, CloudWatch, etc.)
